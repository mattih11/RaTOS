mainmenu "RaTOS Real-Time OS"

config KAS_INCLUDE_MAIN
        string
        default "kas.yaml"

config KAS_BUILD_SYSTEM
        string
        default "isar"

choice
        prompt "Target"
        default TARGET_ODROID_H4

config TARGET_ODROID_H4
        bool "Odroid H4 (Intel Alder Lake-N, amd64 EFI)"

config TARGET_CONTAINER_AMD64
        bool "Developer container image (amd64 docker-archive + QEMU ext4)"
        help
          Builds ratos-dev-image for the container-amd64 machine.
          Produces:
            - docker-archive.gz  (Docker rootfs, load with podman/docker)
            - vmlinuz / initrd.img  (EVL kernel + initrd, separate files)
            - ext4  (raw ext4 rootfs, used by scripts/start-qemu.sh directly)
            - wic.gz  (wic disk image with partition table, for CI releases)
          Boot locally:
            ./scripts/start-qemu.sh

endchoice

config KAS_INCLUDE_TARGET
        string
        default "kas/board/odroid-h4.yaml"       if TARGET_ODROID_H4
        default "kas/board/container-amd64.yaml"  if TARGET_CONTAINER_AMD64

if TARGET_ODROID_H4

choice
        prompt "Image type"
        default IMAGE_SWUPDATE

config IMAGE_SWUPDATE
        bool "Production image with SWUpdate OTA (A/B rootfs, EFI Boot Guard)"
        help
          Produces a .wic for initial flashing and a .swu for OTA updates.
          Uses EFI Boot Guard for A/B slot switching with watchdog rollback.
          Recommended for real deployments.

config IMAGE_SINGLE_ROOT
        bool "Development image (single-root, no OTA)"
        help
          Single-slot ext4 rootfs, EFI Boot Guard, expands partition on first boot.
          Simpler for development but does not support OTA updates.

endchoice

config KAS_INCLUDE_IMAGE_TYPE
        string
        default "kas/opt/swupdate.yaml" if IMAGE_SWUPDATE

endif   # TARGET_ODROID_H4

if TARGET_CONTAINER_AMD64

config BUILD_SDK
        bool "Build cross-compilation SDK"
        help
          After building the rootfs, builds a cross-compilation SDK that lets
          you compile CommRaT (and other packages) on your host machine,
          targeting the EVL sysroot.  The SDK includes:
            - x86_64 → amd64 cross-toolchain (gcc, g++, binutils, sysroot)
            - EVL kernel headers  (linux-headers-xenomai-4)
            - libevl headers and static/shared libraries

          Build the SDK:
            kas-container --isar build \
              kas.yaml:kas/board/container-amd64.yaml \
              -- -c populate_sdk ratos-dev-image

          The SDK installer is written to build/tmp/deploy/sdk/ (or
          build/tmp/deploy/images/container-amd64/).
          See docs/commrat-dev-guide.md for the full cross-compile workflow.

endif   # TARGET_CONTAINER_AMD64
